+static uint8_t *
+convert_png_to_cf_dib (const uint8_t *png_data,
+                       uint32_t       png_size,
+                       uint32_t      *dst_size)
+{
+  GdkPixbufLoader *loader = NULL;
+  GdkPixbuf *pixbuf = NULL;
+  GError *error = NULL;
+  const uint8_t *src_pixels;
+  uint8_t *dib_data;
+  uint32_t width, height, src_rowstride;
+  uint32_t dib_rowstride, total_size;
+  int n_channels, row, col;
+
+  *dst_size = 0;
+
+  loader = gdk_pixbuf_loader_new_with_type ("png", &error);
+  if (!loader)
+    {
+      g_warning ("[RDP.CLIPRDR] PNG to CF_DIB: Failed to create PNG loader: %s",
+                 error->message);
+      g_clear_error (&error);
+      return NULL;
+    }
+
+  if (!gdk_pixbuf_loader_write (loader, png_data, png_size, &error))
+    {
+      g_warning ("[RDP.CLIPRDR] PNG to CF_DIB: Failed to write PNG data: %s",
+                 error->message);
+      g_clear_error (&error);
+      gdk_pixbuf_loader_close (loader, NULL);
+      g_object_unref (loader);
+      return NULL;
+    }
+
+  if (!gdk_pixbuf_loader_close (loader, &error))
+    {
+      g_warning ("[RDP.CLIPRDR] PNG to CF_DIB: Failed to close PNG loader: %s",
+                 error->message);
+      g_clear_error (&error);
+      g_object_unref (loader);
+      return NULL;
+    }
+
+  pixbuf = gdk_pixbuf_loader_get_pixbuf (loader);
+  if (!pixbuf)
+    {
+      g_warning ("[RDP.CLIPRDR] PNG to CF_DIB: No pixbuf from loader");
+      g_object_unref (loader);
+      return NULL;
+    }
+
+  width         = (uint32_t) gdk_pixbuf_get_width (pixbuf);
+  height        = (uint32_t) gdk_pixbuf_get_height (pixbuf);
+  n_channels    = gdk_pixbuf_get_n_channels (pixbuf);
+  src_rowstride = (uint32_t) gdk_pixbuf_get_rowstride (pixbuf);
+  src_pixels    = gdk_pixbuf_get_pixels (pixbuf);
+
+  /* CF_DIB rows must be padded to a 4-byte boundary */
+  dib_rowstride = (width * 3 + 3) & ~3u;
+  total_size    = 40 + dib_rowstride * height;
+
+  dib_data = g_malloc0 (total_size);
+
+  /* BITMAPINFOHEADER (40 bytes, little-endian) */
+  {
+    uint32_t v32; int32_t vi32; uint16_t v16;
+    v32 = 40;                        memcpy (dib_data +  0, &v32,  4); /* biSize */
+    vi32 = (int32_t) width;          memcpy (dib_data +  4, &vi32, 4); /* biWidth */
+    vi32 = (int32_t) height;         memcpy (dib_data +  8, &vi32, 4); /* biHeight (bottom-up) */
+    v16 = 1;                         memcpy (dib_data + 12, &v16,  2); /* biPlanes */
+    v16 = 24;                        memcpy (dib_data + 14, &v16,  2); /* biBitCount */
+    /* biCompression = 0 (BI_RGB), already zeroed */
+    v32 = dib_rowstride * height;    memcpy (dib_data + 20, &v32,  4); /* biSizeImage */
+    /* XPelsPerMeter, YPelsPerMeter, ClrUsed, ClrImportant all 0 */
+  }
+
+  /* Copy pixels: GdkPixbuf is top-down RGB(A); CF_DIB is bottom-up BGR */
+  for (row = 0; row < (int) height; row++)
+    {
+      const uint8_t *src_row = src_pixels +
+                               ((int) height - 1 - row) * (int) src_rowstride;
+      uint8_t *dst_row = dib_data + 40 + (uint32_t) row * dib_rowstride;
+
+      for (col = 0; col < (int) width; col++)
+        {
+          dst_row[col * 3 + 0] = src_row[col * n_channels + 2]; /* B */
+          dst_row[col * 3 + 1] = src_row[col * n_channels + 1]; /* G */
+          dst_row[col * 3 + 2] = src_row[col * n_channels + 0]; /* R */
+        }
+    }
+
+  g_object_unref (loader);
+
+  *dst_size = total_size;
+  return dib_data;
+}
+
+static uint8_t *
+convert_cf_dib_to_png (GrdClipboardRdp *clipboard_rdp,
+                       uint8_t         *src_data,
+                       uint32_t         src_size,
+                       uint32_t        *dst_size)
+{
+  uint32_t bmp_format_id;
+  uint32_t bmp_size = 0;
+  uint8_t *bmp_data = NULL;
+  GdkPixbufLoader *loader = NULL;
+  GdkPixbuf *pixbuf = NULL;
+  GError *error = NULL;
+  gchar *png_data = NULL;
+  gsize png_size = 0;
+
+  *dst_size = 0;
+
+  bmp_format_id = ClipboardGetFormatId (clipboard_rdp->system, "image/bmp");
+  if (!ClipboardSetData (clipboard_rdp->system, CF_DIB, src_data, src_size))
+    {
+      g_warning ("[RDP.CLIPRDR] CF_DIB to PNG: Failed to set DIB data");
+      return NULL;
+    }
+
+  bmp_data = ClipboardGetData (clipboard_rdp->system, bmp_format_id, &bmp_size);
+  if (!bmp_data)
+    {
+      g_warning ("[RDP.CLIPRDR] CF_DIB to PNG: Failed to convert DIB to BMP");
+      return NULL;
+    }
+
+  loader = gdk_pixbuf_loader_new_with_type ("bmp", &error);
+  if (!loader)
+    {
+      g_warning ("[RDP.CLIPRDR] CF_DIB to PNG: Failed to create BMP loader: %s",
+                 error->message);
+      g_clear_error (&error);
+      free (bmp_data);
+      return NULL;
+    }
+
+  if (!gdk_pixbuf_loader_write (loader, bmp_data, bmp_size, &error))
+    {
+      g_warning ("[RDP.CLIPRDR] CF_DIB to PNG: Failed to write BMP data: %s",
+                 error->message);
+      g_clear_error (&error);
+      gdk_pixbuf_loader_close (loader, NULL);
+      g_object_unref (loader);
+      free (bmp_data);
+      return NULL;
+    }
+  free (bmp_data);
+
+  if (!gdk_pixbuf_loader_close (loader, &error))
+    {
+      g_warning ("[RDP.CLIPRDR] CF_DIB to PNG: Failed to close BMP loader: %s",
+                 error->message);
+      g_clear_error (&error);
+      g_object_unref (loader);
+      return NULL;
+    }
+
+  pixbuf = gdk_pixbuf_loader_get_pixbuf (loader);
+  if (!pixbuf)
+    {
+      g_warning ("[RDP.CLIPRDR] CF_DIB to PNG: No pixbuf from loader");
+      g_object_unref (loader);
+      return NULL;
+    }
+
+  if (!gdk_pixbuf_save_to_buffer (pixbuf, &png_data, &png_size,
+                                   "png", &error, NULL))
+    {
+      g_warning ("[RDP.CLIPRDR] CF_DIB to PNG: Failed to encode PNG: %s",
+                 error->message);
+      g_clear_error (&error);
+      g_object_unref (loader);
+      return NULL;
+    }
+
+  g_object_unref (loader);
+
+  *dst_size = (uint32_t) png_size;
+  return (uint8_t *) png_data;
+}
