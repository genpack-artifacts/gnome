vk-image: Always use dedicated allocation for imported images (B580/Xe2)

Based on gnome-remote-desktop MR !401 (f2dc8de834bc) but with one deliberate
deviation: force perform_dedicated_allocation = TRUE for image imports instead
of only when the driver reports prefers/requires.

Rationale (B580/Xe2 regression, 2026-06-13):
On Intel Arc B580 (Xe2) the dma-buf import of the CCS-compressed screencast
image (I915_FORMAT_MOD_4_TILED_BMG_CCS) reports prefersDedicatedAllocation ==
requiresDedicatedAllocation == false. The upstream conditional form therefore
does NOT chain VkMemoryDedicatedAllocateInfo, leaving image == NULL inside
anv_AllocateMemory(). Together with the anv NULL-deref fix carried in
patches/media-libs/mesa/ (which skips the COMPRESSED block when image == NULL),
ANV_BO_ALLOC_SCANOUT (b7f7f1c74f, "Treat imported compressed buffers as
displayable (xe2)") is no longer set for the import, and the displayed frame is
corrupted (tearing / garbage worse than before).

Forcing the dedicated allocation always sets image != NULL on that import, so
anv tags the compressed buffer for scanout again. This is functionally the same
as the previous unconditional 0006 patch, rebuilt on top of upstream's cleaner
target_image plumbing. Buffer (non-image) callers never set
perform_dedicated_allocation, so they are unaffected. AMD is unaffected (it ran
fine with the unconditional form before).

Drop this in favour of plain upstream f2dc8de once anv tags scanout correctly
without a dedicated allocation on Xe2, or once the import reports
prefers/requires.

Upstream behaviour for reference:
When importing a dma-buf image, the Vulkan driver may prefer or even require the
VkImage to have a dedicated allocation. Detect that via the
VK_KHR_dedicated_allocation extension (core in Vulkan 1.1) and add a
VkMemoryDedicatedAllocateInfo to the pNext chain of vkAllocateMemory.

diff --git a/src/grd-vk-image.c b/src/grd-vk-image.c
index 7d23ebf..33481f2 100644
--- a/src/grd-vk-image.c
+++ b/src/grd-vk-image.c
@@ -165,6 +165,7 @@ bind_image_memory (GrdVkImage                  *image,
   VkDevice vk_device = grd_vk_device_get_device (image->device);
   VkImageMemoryRequirementsInfo2 memory_requirements_info_2 = {};
   VkMemoryRequirements2 memory_requirements_2 = {};
+  VkMemoryDedicatedRequirements memory_dedicated_requirements = {};
   GrdVkMemoryDescriptor memory_descriptor = {};
   VkBindImageMemoryInfo bind_image_memory_info = {};
   VkResult vk_result;
@@ -173,6 +174,11 @@ bind_image_memory (GrdVkImage                  *image,
     VK_STRUCTURE_TYPE_IMAGE_MEMORY_REQUIREMENTS_INFO_2;
   memory_requirements_info_2.image = image->vk_image;
   memory_requirements_2.sType = VK_STRUCTURE_TYPE_MEMORY_REQUIREMENTS_2;
+  memory_dedicated_requirements.sType =
+    VK_STRUCTURE_TYPE_MEMORY_DEDICATED_REQUIREMENTS;
+
+  grd_vk_append_to_chain (&memory_requirements_2,
+                          &memory_dedicated_requirements);
 
   vkGetImageMemoryRequirements2 (vk_device, &memory_requirements_info_2,
                                  &memory_requirements_2);
@@ -181,6 +187,21 @@ bind_image_memory (GrdVkImage                  *image,
   memory_descriptor.memory_flags = image_descriptor->memory_flags;
   memory_descriptor.import_handle_type = image_descriptor->import_handle_type;
   memory_descriptor.fd = image_descriptor->fd;
+  memory_descriptor.target_image = image->vk_image;
+
+  /* genpack/B580 deviation from upstream f2dc8de:
+   * Always request a dedicated allocation for imported images instead of only
+   * when prefers/requires is set. On Intel Arc B580 (Xe2) the dma-buf import of
+   * the CCS-compressed screencast image reports prefers/requires == false, so
+   * the upstream conditional form leaves image == NULL in anv_AllocateMemory.
+   * Combined with the anv NULL-deref fix (which skips the COMPRESSED block when
+   * image == NULL), that drops ANV_BO_ALLOC_SCANOUT (b7f7f1c74f) for the import
+   * and corrupts the displayed frame (tearing/garbage). Forcing image != NULL
+   * here restores SCANOUT tagging. AMD is unaffected (worked with the old
+   * unconditional 0006 too). The prefers/requires query above is left in place
+   * but intentionally unused (the struct is still chained into and written by
+   * vkGetImageMemoryRequirements2, so there is no unused-variable warning). */
+  memory_descriptor.perform_dedicated_allocation = TRUE;
 
   image->memory = grd_vk_memory_new (image->device, &memory_descriptor, error);
   if (!image->memory)
diff --git a/src/grd-vk-memory.c b/src/grd-vk-memory.c
index 221ebeb..570b2d4 100644
--- a/src/grd-vk-memory.c
+++ b/src/grd-vk-memory.c
@@ -180,6 +180,7 @@ grd_vk_memory_new (GrdVkDevice                  *device,
   g_autoptr (GrdVkMemory) memory = NULL;
   VkMemoryAllocateInfo memory_allocate_info = {};
   VkImportMemoryFdInfoKHR import_memory_fd_info = {};
+  VkMemoryDedicatedAllocateInfo dedicated_allocate_info = {};
   uint32_t memory_type_bits;
   VkResult vk_result;
 
@@ -209,6 +210,15 @@ grd_vk_memory_new (GrdVkDevice                  *device,
       return NULL;
     }
 
+  if (memory_descriptor->perform_dedicated_allocation)
+    {
+      dedicated_allocate_info.sType =
+        VK_STRUCTURE_TYPE_MEMORY_DEDICATED_ALLOCATE_INFO;
+      dedicated_allocate_info.image = memory_descriptor->target_image;
+
+      grd_vk_append_to_chain (&memory_allocate_info, &dedicated_allocate_info);
+    }
+
   vk_result = vkAllocateMemory (vk_device, &memory_allocate_info, NULL,
                                 &memory->vk_memory);
   if (vk_result != VK_SUCCESS)
diff --git a/src/grd-vk-memory.h b/src/grd-vk-memory.h
index f17ff96..e05504d 100644
--- a/src/grd-vk-memory.h
+++ b/src/grd-vk-memory.h
@@ -36,6 +36,10 @@ typedef struct
   /* Only for import operations */
   VkExternalMemoryHandleTypeFlagBits import_handle_type;
   int fd;
+
+  /* Only for dedicated allocations */
+  gboolean perform_dedicated_allocation;
+  VkImage target_image;
 } GrdVkMemoryDescriptor;
 
 GrdVkMemory *grd_vk_memory_new (GrdVkDevice                  *device,
